# Gemini API
# https://aistudio.google.com/app/apikey で取得
GEMINI_API_KEY=your_gemini_api_key_here

# X (Twitter) API v2
# https://developer.twitter.com/en/portal/dashboard で取得
# ※ Read and Write 権限が必要
X_API_KEY=your_x_api_key_here
X_API_SECRET=your_x_api_secret_here
X_ACCESS_TOKEN=your_x_access_token_here
X_ACCESS_SECRET=your_x_access_secret_here

# 自動いいね・リポスト設定
# いいね: 1時間ごとに最大2件 = 1日最大48件
# リポスト: 3時間ごとに最大1件 = 1日最大8件
AUTO_LIKE_MAX_PER_RUN=2
AUTO_REPOST_MAX_PER_RUN=1
